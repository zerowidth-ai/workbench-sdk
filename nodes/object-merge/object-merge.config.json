{
  "display_name": "Object Merge",
  "tagline": "Merge objects together",
  "description": "Deep merges multiple objects into one. Later objects override earlier ones. Nested objects are recursively merged.",
  "icon": "object-group",
  "category": "data",
  "inputs": [
    {
      "name": "objects",
      "display_name": "Objects",
      "type": "object",
      "description": "Objects to merge (later objects override earlier ones)",
      "required": true,
      "allow_multiple": true
    },
    {
      "name": "array_mode",
      "display_name": "Array Mode",
      "type": "string",
      "description": "How to handle array values",
      "required": false,
      "default": "replace",
      "options": ["replace", "concat"]
    }
  ],
  "outputs": [
    {
      "name": "merged",
      "display_name": "Merged",
      "type": "object",
      "description": "The merged object"
    }
  ]
}
