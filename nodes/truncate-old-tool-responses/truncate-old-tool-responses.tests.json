[
  {
    "description": "Truncate old tool responses outside recent window",
    "inputs": {
      "messages": [
        {"role": "user", "content": "Old question"},
        {"role": "assistant", "content": null, "tool_calls": [{"id": "call_1", "function": {"name": "get_data"}}]},
        {"role": "tool", "tool_call_id": "call_1", "content": "This is a very long response that should be truncated"},
        {"role": "assistant", "content": "Here's the old data"},
        {"role": "user", "content": "New question"},
        {"role": "assistant", "content": "New response"}
      ],
      "keep_recent": 3
    },
    "expected": {
      "messages": [
        {"role": "user", "content": "Old question"},
        {"role": "assistant", "content": null, "tool_calls": [{"id": "call_1", "function": {"name": "get_data"}}]},
        {"role": "tool", "tool_call_id": "call_1", "content": "[Truncated]"},
        {"role": "assistant", "content": "Here's the old data"},
        {"role": "user", "content": "New question"},
        {"role": "assistant", "content": "New response"}
      ],
      "truncated_count": 1
    }
  },
  {
    "description": "Keep recent tool responses intact",
    "inputs": {
      "messages": [
        {"role": "user", "content": "Question"},
        {"role": "assistant", "content": null, "tool_calls": [{"id": "call_1", "function": {"name": "get_weather"}}]},
        {"role": "tool", "tool_call_id": "call_1", "content": "Sunny, 72F"},
        {"role": "assistant", "content": "The weather is sunny!"}
      ],
      "keep_recent": 10
    },
    "expected": {
      "messages": [
        {"role": "user", "content": "Question"},
        {"role": "assistant", "content": null, "tool_calls": [{"id": "call_1", "function": {"name": "get_weather"}}]},
        {"role": "tool", "tool_call_id": "call_1", "content": "Sunny, 72F"},
        {"role": "assistant", "content": "The weather is sunny!"}
      ],
      "truncated_count": 0
    }
  },
  {
    "description": "Custom placeholder",
    "inputs": {
      "messages": [
        {"role": "tool", "tool_call_id": "call_1", "content": "Long response here"},
        {"role": "user", "content": "Recent message"}
      ],
      "keep_recent": 1,
      "placeholder": "[Response removed for context compression]"
    },
    "expected": {
      "messages": [
        {"role": "tool", "tool_call_id": "call_1", "content": "[Response removed for context compression]"},
        {"role": "user", "content": "Recent message"}
      ],
      "truncated_count": 1
    }
  },
  {
    "description": "Passthrough when no tool messages",
    "inputs": {
      "messages": [
        {"role": "user", "content": "Hello"},
        {"role": "assistant", "content": "Hi there!"},
        {"role": "user", "content": "How are you?"}
      ],
      "keep_recent": 2
